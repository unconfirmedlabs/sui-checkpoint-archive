{
  "name": "@unconfirmedlabs/sui-checkpoint-archive",
  "version": "0.1.0",
  "description": "Client SDK for the unconfirmedlabs Sui checkpoint archive. BLS-verified, CDN-cached, globally replicated.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "sui-archive": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./binary": {
      "types": "./src/binary.ts",
      "import": "./src/binary.ts",
      "default": "./src/binary.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/unconfirmedlabs/sui-checkpoint-archive.git",
    "directory": "client"
  },
  "keywords": ["sui", "checkpoint", "archive", "blockchain", "light-client", "bls"]
}
